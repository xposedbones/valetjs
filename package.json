{
  "name": "valetjs",
  "version": "1.0.1",
  "description": "Lightweight directive and web component lifecycle management for the DOM, powered by MutationObserver. Lazy-load directives and components only when their selectors appear on the page.",
  "keywords": [
    "directive",
    "web-components",
    "mutation-observer",
    "lazy-loading",
    "lit",
    "dom",
    "lifecycle",
    "typescript"
  ],
  "author": "xposedbones",
  "license": "MIT",
  "homepage": "https://github.com/xposedbones/valetjs#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xposedbones/valetjs.git"
  },
  "bugs": {
    "url": "https://github.com/xposedbones/valetjs/issues"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "build:demo": "vite build",
    "dev": "vite demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "peerDependencies": {
    "lit": ">=3.0.0"
  },
  "devDependencies": {
    "lit": "^3.2.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0"
  }
}
